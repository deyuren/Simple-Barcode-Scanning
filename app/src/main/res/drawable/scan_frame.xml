<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 四个角落 -->
    <!-- 左上角 -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="0dp" android:color="@android:color/transparent"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

    <!-- 使用corner drawable -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#2979FF"/>
            <solid android:color="#1A2979FF"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</layer-list>
